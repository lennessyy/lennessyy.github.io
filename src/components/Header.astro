---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
];
const currentPath = Astro.url.pathname;
---

<header class="flex items-center justify-between py-6">
  <nav class="flex items-center gap-5">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'text-sm transition-colors',
          currentPath === href || (href !== '/' && currentPath.startsWith(href))
            ? 'text-[var(--color-accent)] font-medium'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-heading)]',
        ]}
      >
        {label}
      </a>
    ))}
  </nav>
  <button
    id="theme-toggle"
    class="text-[var(--color-text-secondary)] hover:text-[var(--color-heading)] transition-colors"
    aria-label="Toggle theme"
  >
    <!-- Sun icon (shown in dark mode) -->
    <svg class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <!-- Moon icon (shown in light mode) -->
    <svg class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    document.documentElement.classList.add('transitioning');
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    setTimeout(() => document.documentElement.classList.remove('transitioning'), 300);
  });
</script>
