---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.pubDate);
---

<BaseLayout title={`${frontmatter.title} — Lenny Chen`} description={frontmatter.description}>
  <article>
    <header class="mb-8">
      <h1 class="text-2xl font-bold text-[var(--color-heading)]">{frontmatter.title}</h1>
      <time class="mt-2 block text-sm text-[var(--color-text-secondary)]" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-2 text-sm text-[var(--color-text-secondary)]">
          {frontmatter.tags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
